@page "/"
@using System.Net.Http.Json
@using Caimmand.Domain
@using Caimmand.Domain.Entities
@using Caimmand.Domain.Enums
@using Microsoft.EntityFrameworkCore
@inject ICaimmandDbContext Db

<PageTitle>Caimmand PoC</PageTitle>

<div class="container mt-5">
    <div class="row">
        <div class="col-lg-10 offset-lg-1">
            <h1 class="display-5 fw-semibold">Caimmand PoC</h1>
            <p class="lead text-muted">Version 0.1</p>
            <hr class="my-4" />
            <p class="fs-5">
                Caimmand no ejecuta el negocio; hace visible, gobernable y operable su ejecucion.
            </p>

            @if (Total == 0)
            {
                <div class="alert alert-info mt-4" role="alert">
                    Aun no hay casos. Crea el primero con <code>POST /cases</code>.
                </div>
            }
            else
            {
                <div class="row g-3 mt-4">
                    <div class="col-md-4">
                        <div class="card text-center shadow-sm">
                            <div class="card-body">
                                <h6 class="card-subtitle mb-2 text-muted">Total de Casos</h6>
                                <p class="display-4 fw-semibold mb-0">@Total</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card text-center shadow-sm">
                            <div class="card-body">
                                <h6 class="card-subtitle mb-2 text-muted">Casos Creados</h6>
                                <p class="display-4 fw-semibold mb-0">@Created</p>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private int Total = 0;
    private int Created = 0;

    protected override async Task OnInitializedAsync()
    {
        Total = await Db.Cases.CountAsync();
        Created = await Db.Cases.CountAsync(c => c.Status == CaseStatus.Creado);
    }
}