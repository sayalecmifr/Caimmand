@page "/"
@using Caimmand.Application.Dashboard.GetDashboardKpis
@using Caimmand.Domain.Enums
@inject GetDashboardKpisHandler DashboardHandler
@inject NavigationManager Nav

<PageTitle>Caimmand PoC · Dashboard</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-6 fw-semibold mb-0">Dashboard</h1>
            <p class="text-muted mb-0">Estado operativo de los casos gobernados por Caimmand.</p>
        </div>
        <button class="btn btn-outline-primary" @onclick="GoToCases">
            Ver casos
        </button>
    </div>

    @if (Kpis is null)
    {
        <div class="text-center py-5 text-muted">
            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
            Cargando...
        </div>
    }
    else if (Kpis.Total == 0)
    {
        <div class="alert alert-info" role="alert">
            No hay casos registrados.
            <span class="text-muted">Crea el primero con <code>POST /cases</code>.</span>
        </div>
    }
    else
    {
        <div class="row g-3">
            <div class="col-md-3">
                <div class="card text-center shadow-sm h-100">
                    <div class="card-body">
                        <h6 class="card-subtitle mb-2 text-muted">Total de Casos</h6>
                        <p class="display-4 fw-semibold mb-0">@Kpis.Total</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center shadow-sm h-100">
                    <div class="card-body">
                        <h6 class="card-subtitle mb-2 text-muted">Creados</h6>
                        <p class="display-4 fw-semibold mb-0 text-primary">@Kpis.Created</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center shadow-sm h-100">
                    <div class="card-body">
                        <h6 class="card-subtitle mb-2 text-muted">Finalizados</h6>
                        <p class="display-4 fw-semibold mb-0 text-success">@Kpis.Finalizados</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center shadow-sm h-100 border-warning">
                    <div class="card-body">
                        <h6 class="card-subtitle mb-2 text-muted">Requieren Intervencion</h6>
                        <p class="display-4 fw-semibold mb-0 text-warning">@Kpis.RequierenIntervencion</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-5 text-muted small">
            <span class="fw-semibold">Caimmand PoC · v0.1</span>
            <span class="mx-2">·</span>
            <span>Caimmand no ejecuta el negocio; hace visible, gobernable y operable su ejecucion.</span>
        </div>
    }
</div>

@code {
    private DashboardKpis? Kpis;

    protected override async Task OnInitializedAsync()
    {
        Kpis = await DashboardHandler.Handle(new GetDashboardKpisQuery(), default);
    }

    private void GoToCases() => Nav.NavigateTo("/cases");
}