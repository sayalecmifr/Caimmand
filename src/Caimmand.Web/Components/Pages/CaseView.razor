@page "/cases/{Id:Guid}"
@using System.Text.Json
@using Caimmand.Application.Cases.GetDetail
@using Caimmand.Application.Cases.UpdateStatus
@using Caimmand.Application.Timeline.GetTimeline
@using Caimmand.Domain.Enums
@inject GetCaseDetailHandler DetailHandler
@inject GetTimelineHandler TimelineHandler
@inject UpdateCaseStatusHandler StatusHandler
@inject NavigationManager Nav

<PageTitle>Caimmand PoC · Detalle del Caso</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a href="/cases" class="text-decoration-none small">&larr; Volver al listado</a>
            <h1 class="display-6 fw-semibold mb-0 mt-1">Detalle del Caso</h1>
        </div>
    </div>

    @if (Loading)
    {
        <div class="text-center py-5 text-muted">
            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
            Cargando...
        </div>
    }
    else if (Case is null)
    {
        <div class="alert alert-warning" role="alert">
            No se encontro el caso solicitado.
            <button class="btn btn-sm btn-outline-secondary ms-3" @onclick="GoBack">Volver al listado</button>
        </div>
    }
    else
    {
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                    <div class="flex-grow-1">
                        <h2 class="h4 fw-semibold mb-1">@Case.Title</h2>
                        <div class="text-muted small">
                            <span class="fw-semibold">@Case.CaseDefinitionName</span>
                            <span class="mx-1">·</span>
                            <code>@Case.CaseDefinitionCode</code>
                        </div>
                    </div>
                    <span class="@StatusBadgeClass(Case.Status) fs-6">@StatusLabel(Case.Status)</span>
                </div>
                <hr class="my-3" />
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="text-muted small">Sistema origen</div>
                        <div class="fw-semibold">@Case.SourceSystem</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted small">Fecha de creacion</div>
                        <div class="fw-semibold">@Case.CreatedAt.ToLocalTime().ToString("f")</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted small">Ultima actualizacion</div>
                        <div class="fw-semibold">@Case.UpdatedAt.ToLocalTime().ToString("f")</div>
                    </div>
                </div>
                <div class="row g-3 mt-1">
                    <div class="col-md-12">
                        <div class="text-muted small">Identificador</div>
                        <code class="text-body">@Case.Id</code>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h3 class="h6 fw-semibold mb-3">Contexto</h3>
                <pre class="bg-light border p-3 rounded font-monospace small mb-0" style="white-space: pre-wrap;">@ContextPrettyJson</pre>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-7">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h3 class="h6 fw-semibold mb-3">Timeline</h3>
                        @if (Timeline is null || Timeline.Count == 0)
                        {
                            <p class="text-muted mb-0">No hay eventos registrados.</p>
                        }
                        else
                        {
                            <div class="d-flex flex-column gap-3">
                                @foreach (var item in Timeline)
                                {
                                    <div class="border-start border-3 border-primary ps-3">
                                        <div class="d-flex justify-content-between align-items-baseline">
                                            <span class="fw-semibold">@item.Type</span>
                                            <small class="text-muted">@item.OccurredAt.ToLocalTime().ToString("g")</small>
                                        </div>
                                        <div class="text-muted small mb-1">@item.Origin</div>
                                        <div>@item.Content</div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-5">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h3 class="h6 fw-semibold mb-3">Acciones</h3>
                        @{
                            var targets = CaseStatusTransitions.GetValidTargets(Case.Status);
                        }
                        @if (targets.Count == 0)
                        {
                            <p class="text-muted mb-0">El caso se encuentra en estado terminal (@StatusLabel(Case.Status)).</p>
                        }
                        else
                        {
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var target in targets)
                                {
                                    <button class="btn btn-outline-primary btn-sm" @onclick="() => ChangeStatus(target)">
                                        @StatusLabel(target)
                                    </button>
                                }
                            </div>
                            @if (StatusError is not null)
                            {
                                <div class="text-danger small mt-2">@StatusError</div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string? Id { get; set; }

    private CaseDetail? Case;
    private IReadOnlyList<TimelineEventItem>? Timeline;
    private bool Loading = true;
    private string ContextPrettyJson = string.Empty;
    private string? StatusError;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        if (Guid.TryParse(Id, out var caseId))
        {
            Case = await DetailHandler.Handle(new GetCaseDetailQuery(caseId), default);
            Timeline = await TimelineHandler.Handle(new GetTimelineQuery(caseId), default);
            if (Case is not null)
            {
                ContextPrettyJson = JsonSerializer.Serialize(Case.Context.RootElement, new JsonSerializerOptions
                {
                    WriteIndented = true
                });
            }
        }
        Loading = false;
    }

    private async Task ChangeStatus(CaseStatus newStatus)
    {
        if (Case is null) return;
        StatusError = null;
        try
        {
            await StatusHandler.Handle(new UpdateCaseStatusCommand(Case.Id, newStatus), default);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            StatusError = ex.Message;
        }
    }

    private void GoBack() => Nav.NavigateTo("/cases");

    private static string StatusLabel(CaseStatus s) => s switch
    {
        CaseStatus.Creado => "Creado",
        CaseStatus.EnCurso => "En curso",
        CaseStatus.Suspendido => "Suspendido",
        CaseStatus.Finalizado => "Finalizado",
        CaseStatus.Cancelado => "Cancelado",
        _ => s.ToString()
    };

    private static string StatusBadgeClass(CaseStatus s) => s switch
    {
        CaseStatus.Creado => "badge bg-primary",
        CaseStatus.EnCurso => "badge bg-info",
        CaseStatus.Suspendido => "badge bg-warning text-dark",
        CaseStatus.Finalizado => "badge bg-success",
        CaseStatus.Cancelado => "badge bg-danger",
        _ => "badge bg-secondary"
    };
}