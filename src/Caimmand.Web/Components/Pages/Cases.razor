@page "/cases"
@using Caimmand.Application.CaseDefinitions.List
@using Caimmand.Application.Cases.List
@using Caimmand.Domain.Enums
@inject ListCasesHandler ListHandler
@inject ListCaseDefinitionsHandler DefinitionsHandler
@inject NavigationManager Nav

<PageTitle>Caimmand PoC · Casos</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-6 fw-semibold mb-0">Casos</h1>
            <p class="text-muted mb-0">Listado de casos gobernados por Caimmand.</p>
        </div>
        <a href="/" class="btn btn-link text-decoration-none">
            &larr; Volver al Dashboard
        </a>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small text-muted mb-1">Estado</label>
                    <select class="form-select" @bind="SelectedStatus" @bind:event="onchange" @bind:after="OnFilterChanged">
                        <option value="">Todos</option>
                        @foreach (var status in Enum.GetValues<CaseStatus>())
                        {
                            <option value="@status">@StatusLabel(status)</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small text-muted mb-1">Case Definition</label>
                    <select class="form-select" @bind="SelectedCode" @bind:event="onchange" @bind:after="OnFilterChanged">
                        <option value="">Todas</option>
                        @if (Definitions is not null)
                        {
                            @foreach (var def in Definitions)
                            {
                                <option value="@def.Code">@def.Name (@def.Code)</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-outline-secondary w-100" @onclick="ClearFilters">
                        Limpiar
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (Items is null)
    {
        <div class="text-center py-5 text-muted">
            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
            Cargando...
        </div>
    }
    else if (Items.Count == 0)
    {
        <div class="alert alert-info" role="alert">
            No existen casos para mostrar.
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">Titulo</th>
                            <th scope="col">Case Definition</th>
                            <th scope="col">Estado</th>
                            <th scope="col">Sistema origen</th>
                            <th scope="col">Fecha creacion</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Items)
                        {
                            <tr role="button" tabindex="0" style="cursor: pointer;"
                               @onclick="() => Open(item.Id)"
                               @onkeypress="() => Open(item.Id)">
                                <td class="fw-semibold">@item.Title</td>
                                <td>
                                    <div>@item.CaseDefinitionName</div>
                                    <div class="text-muted small">@item.CaseDefinitionCode</div>
                                </td>
                                <td><span class="@StatusBadgeClass(item.Status)">@StatusLabel(item.Status)</span></td>
                                <td>@item.SourceSystem</td>
                                <td class="text-muted">@item.CreatedAt.ToLocalTime().ToString("g")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-3 text-muted small">
            @Items.Count caso(s) encontrado(s).
        </div>
    }
</div>

@code {
    private IReadOnlyList<CaseListItem>? Items;
    private IReadOnlyList<CaseDefinitionItem>? Definitions;
    private CaseStatus? SelectedStatus;
    private string? SelectedCode;

    protected override async Task OnInitializedAsync()
    {
        Definitions = await DefinitionsHandler.Handle(new ListCaseDefinitionsQuery(), default);
        await LoadAsync();
    }

    private async Task OnFilterChanged()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        Items = await ListHandler.Handle(new ListCasesQuery(SelectedStatus, SelectedCode), default);
    }

    private async Task ClearFilters()
    {
        SelectedStatus = null;
        SelectedCode = null;
        await LoadAsync();
    }

    private void Open(Guid id) => Nav.NavigateTo($"/cases/{id}");

    private static string StatusLabel(CaseStatus s) => s switch
    {
        CaseStatus.Creado => "Creado",
        CaseStatus.EnCurso => "En curso",
        CaseStatus.Suspendido => "Suspendido",
        CaseStatus.Finalizado => "Finalizado",
        CaseStatus.Cancelado => "Cancelado",
        _ => s.ToString()
    };

    private static string StatusBadgeClass(CaseStatus s) => s switch
    {
        CaseStatus.Creado => "badge bg-primary",
        CaseStatus.EnCurso => "badge bg-info",
        CaseStatus.Suspendido => "badge bg-warning text-dark",
        CaseStatus.Finalizado => "badge bg-success",
        CaseStatus.Cancelado => "badge bg-danger",
        _ => "badge bg-secondary"
    };
}